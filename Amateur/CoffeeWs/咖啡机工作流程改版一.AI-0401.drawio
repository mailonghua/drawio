        <mxCell id="7zS8ADJ6PJcQT8_YQ5GI-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=16;fontStyle=1" value="咖啡锅炉的阶段压力范围：0-16BAR&lt;br&gt;单阶段：0-60秒&lt;br&gt;总控：6分钟" vertex="1">
          <mxGeometry height="90" width="280" x="-1930" y="-1960" as="geometry" />
        </mxCell>
        <mxCell id="7zS8ADJ6PJcQT8_YQ5GI-2" parent="1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" value="" vertex="1">
          <mxGeometry height="195.03" width="295.59" x="-1515.59" y="-2065.03" as="geometry" />
        </mxCell>
        <mxCell id="7zS8ADJ6PJcQT8_YQ5GI-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=14;" value="这个我就真不太清楚了，时间太长了，当时也是实验了很久。但现在使用下来能看到的就是：它会距离你设定的温度低于5度左右开始有停顿，刚开始的停顿间隔不频繁，后面就越来约频繁了。比方说：设定90.1度，到了90它就开始加热了，到90.1度就停了。如到了80度，就直接加热。" vertex="1">
          <mxGeometry height="70" width="350" x="-1930" y="-1750" as="geometry" />
        </mxCell>
        <mxCell id="7zS8ADJ6PJcQT8_YQ5GI-4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=14;" value="锅炉的加热--提供的加热工程思路，实际以测试为主" vertex="1">
          <mxGeometry height="30" width="280" x="-1930" y="-1790" as="geometry" />
        </mxCell>
        <mxCell id="7zS8ADJ6PJcQT8_YQ5GI-5" parent="1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" value="" vertex="1">
