        <UserObject label="# SonicDance.action&#xa;# 用于封装 Sonic 角色的舞蹈动作执行任务&#xa;&#xa;# ============================================================================&#xa;# GOAL: 客户端提交舞蹈任务请求&#xa;# ============================================================================&#xa;goal&#xa;  # --- 核心任务标识 ---&#xa;  string dance_type           # 舞蹈类型: &quot;moonwalk&quot;|&quot;spin&quot;|&quot;freestyle&quot;|...&#xa;  string dance_id             # 自定义任务ID，用于日志追踪和结果查询&#xa;    &#xa;  # --- 高级控制参数 ---&#xa;  geometry_msgs/Pose start_pose  # 起始位姿（可选，用于定位校准）&#xa;  float32 max_duration_sec    # 最大执行时长(秒)，0表示无限制，用于安全兜底&#xa;  &#xa;  # --- 行为标志位 ---&#xa;  bool preemptible            # 是否允许中途被新目标抢占&#xa;&#xa;# ============================================================================&#xa;# RESULT: 任务完成后的最终结果&#xa;# ============================================================================&#xa;result&#xa;  # --- 执行状态 ---&#xa;  int8 execution_status       # 标准状态码: 1=SUCCESS, 2=ABORTED, 3=CANCELED&#xa;  string status_message       # 人类可读的状态描述&#xa;  &#xa;  # --- 执行统计 ---&#xa;  float32 actual_duration     # 实际执行时长(秒)&#xa;&#xa;&#xa;# ============================================================================&#xa;# FEEDBACK: 执行过程中的周期性状态反馈&#xa;# ============================================================================&#xa;feedback&#xa;  # --- 进度信息 ---&#xa;  float32 progress_percent    # 整体进度: 0.0~100.0&#xa;  string current_motion       # 当前正在执行的动作片段名称&#xa;  &#xa;  # --- 时序同步 ---&#xa;  float32 beat_position       # 当前节拍位置: 0.0~1.0 (一个节拍内的相对位置)&#xa;  int64 music_timestamp_ms    # 同步的音乐时间戳(毫秒)，用于音画同步校准&#xa;  &#xa;  # --- 执行状态 ---&#xa;  int8 motion_state           # 动作状态: 0=IDLE, 1=STARTING, 2=EXECUTING, 3=TRANSITIONING, 4=FINISHING&#xa;  &#xa;  # --- 诊断信息 ---&#xa;  string[] active_warnings    # 当前激活的警告列表: [&quot;joint_limit_near&quot;, &quot;slip_detected&quot;, ...]" link="# SonicDance.action&#xa;# 用于封装 Sonic 角色的舞蹈动作执行任务&#xa;&#xa;# ============================================================================&#xa;# GOAL: 客户端提交舞蹈任务请求&#xa;# ============================================================================&#xa;goal&#xa;  # --- 核心任务标识 ---&#xa;  string dance_type           # 舞蹈类型: &quot;moonwalk&quot;|&quot;spin&quot;|&quot;freestyle&quot;|...&#xa;  string dance_id             # 自定义任务ID，用于日志追踪和结果查询&#xa;    &#xa;  # --- 高级控制参数 ---&#xa;  geometry_msgs/Pose start_pose  # 起始位姿（可选，用于定位校准）&#xa;  float32 max_duration_sec    # 最大执行时长(秒)，0表示无限制，用于安全兜底&#xa;  &#xa;  # --- 行为标志位 ---&#xa;  bool preemptible            # 是否允许中途被新目标抢占&#xa;&#xa;# ============================================================================&#xa;# RESULT: 任务完成后的最终结果&#xa;# ============================================================================&#xa;result&#xa;  # --- 执行状态 ---&#xa;  int8 execution_status       # 标准状态码: 1=SUCCESS, 2=ABORTED, 3=CANCELED&#xa;  string status_message       # 人类可读的状态描述&#xa;  &#xa;  # --- 执行统计 ---&#xa;  float32 actual_duration     # 实际执行时长(秒)&#xa;&#xa;&#xa;# ============================================================================&#xa;# FEEDBACK: 执行过程中的周期性状态反馈&#xa;# ============================================================================&#xa;feedback&#xa;  # --- 进度信息 ---&#xa;  float32 progress_percent    # 整体进度: 0.0~100.0&#xa;  string current_motion       # 当前正在执行的动作片段名称&#xa;  &#xa;  # --- 时序同步 ---&#xa;  float32 beat_position       # 当前节拍位置: 0.0~1.0 (一个节拍内的相对位置)&#xa;  int64 music_timestamp_ms    # 同步的音乐时间戳(毫秒)，用于音画同步校准&#xa;  &#xa;  # --- 执行状态 ---&#xa;  int8 motion_state           # 动作状态: 0=IDLE, 1=STARTING, 2=EXECUTING, 3=TRANSITIONING, 4=FINISHING&#xa;  &#xa;  # --- 诊断信息 ---&#xa;  string[] active_warnings    # 当前激活的警告列表: [&quot;joint_limit_near&quot;, &quot;slip_detected&quot;, ...]" id="qzNTs-UY0wei0addMZY_-2">
