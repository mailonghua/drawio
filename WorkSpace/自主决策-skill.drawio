        <mxCell id="qzNTs-UY0wei0addMZY_-21" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontStyle=1;fontColor=#FF3333;fontSize=14;" value="笛卡儿空间位置话题消息定义" vertex="1">
          <mxGeometry height="30" width="200" x="840" y="940" as="geometry" />
